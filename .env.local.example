# Neon PostgreSQL (Database serverless per Vercel)
# Ottieni da: https://neon.tech → Dashboard → Connection String
DATABASE_URL=postgresql://username:password@host.neon.tech/newsita?sslmode=require

# News API Keys (scegli almeno una)
# NewsAPI: https://newsapi.org/register (gratis 100 req/giorno)
NEWSAPI_KEY=your-newsapi-key
# GNews: https://gnews.io/register (gratis 100 req/giorno)
GNEWS_API_KEY=your-gnews-key

# AI Configuration (OpenAI per riscrittura notizie)
# Crea su: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Site Configuration
SITE_URL=https://your-site.vercel.app
SITE_NAME=NewsITA

# Cron Secret (per proteggere endpoint /api/cron/fetch-news)
# Genera stringa casuale: https://generate.plus/en/base64
CRON_SECRET=your-cron-secret-key
